[color]
        ui = true
[alias]
        st = status
        co = checkout
	lg = log --color --graph --pretty=format:'%C(red)%h%Creset - %s %C(green)(%cr) %C(bold blue)<%an>%Creset%C(yellow)%d%Creset' --abbrev-commit
[core]
        excludesfile = ~/.gitignore
        editor = vim
[apply]
        whitespace = nowarn
